# Gene Prioritizer AI — Environment Variable Contract
#
# This file lists every environment variable used across the full project
# plan (Phases 1-12), even though most are not consumed by Phase 1 code
# yet. Listing them now keeps the full contract visible from the start.
# See docs/PHASE_0_ARCHITECTURE.md for which phase introduces each one.
#
# NEVER commit a real .env file. NEVER put a real secret in this file.
# Copy this file to .env.local for local development:
#   cp .env.example .env.local

# --- Core app -----------------------------------------------------------

# Public base URL of the app. Safe to expose to the browser.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Database (introduced in Phase 2) ------------------------------------

# PostgreSQL connection string for production / Docker / hosted deploys.
# For local dev without PostgreSQL, Phase 2 documents a SQLite fallback
# using a file-based DATABASE_URL instead (e.g. file:./dev.db).
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/gene_prioritizer

# --- LLM provider (introduced in Phase 6) --------------------------------
# All LLM usage is optional. With DISABLE_LLM=true, the HPO-code and
# candidate-gene workflows work fully without any of these keys.

LLM_PROVIDER=none
LLM_MODEL=
DISABLE_LLM=true

# Provide at most one of these, matching LLM_PROVIDER. Never required.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# --- NCBI / PubMed (introduced in Phase 7) -------------------------------
# Optional. Increases NCBI E-utilities rate limits if provided.

NCBI_API_KEY=
NCBI_EMAIL=

# --- Admin / ingestion (introduced in Phase 9-10) ------------------------
# Shared secret required on all /api/admin/* and /api/import/* routes.
# Generate a long random value; never reuse across environments.
ADMIN_INGEST_SECRET=change-me-to-a-long-random-value

# --- Rate limiting / cache (introduced in Phase 7/9) ---------------------

RATE_LIMIT_ENABLED=true
# Optional. If unset, an in-memory rate limiter/cache fallback is used
# instead of Upstash Redis (suitable for local dev / single-instance only).
REDIS_URL=

# --- HPO data (introduced in Phase 3) ------------------------------------

HPO_DATA_DIR=./data/hpo

# --- GeneCards integration (introduced in Phase 4/10) --------------------
# Linkout (outbound links only, no fetching) is safe to enable by default.
# Licensed import requires the admin to already hold a valid license for
# data they upload themselves; it is never auto-fetched. See
# DATA_SOURCES.md and SECURITY.md before enabling.

GENE_CARDS_LINKOUT_ENABLED=true
GENE_CARDS_LICENSED_IMPORT_ENABLED=false

# --- Optional future enrichment (introduced in later phases, if ever) ----

OMIM_API_KEY=
EXOMISER_API_URL=

# --- Logging --------------------------------------------------------------

LOG_LEVEL=info
